---
const today = new Date();
---

<footer>
	<div class="social-links">
		<a href="https://github.com/EdgarReyesRivera" target="_blank" rel="noopener noreferrer">GitHub</a>
		<a href="https://www.linkedin.com/in/edgar-reyes-rivera/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
		<!-- email_off/email_off comments tell Cloudflare's Email Address Obfuscation
		     to leave this alone — its decode script doesn't re-run after view-transition
		     navigations, leaving "[email protected]" and a dead /cdn-cgi/ link. -->
		<!--email_off--><a href="mailto:edgar@reyesrivera.dev">Email</a><!--/email_off-->
		</div>
	<div class="license-info">
		&copy; {today.getFullYear()} Edgar Reyes-Rivera. All rights reserved. <br />
		Code licensed under <a href="https://github.com/EdgarReyesRivera/personal-website/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT</a>.
		Content licensed under <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC 4.0</a>.
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 4em 1em;
		background: var(--page-background);
		color: var(--font-color);
		text-align: center;
		opacity: 0.8;
		border-top: 1px solid var(--border-subtle);
		margin-top: 2em;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1.5em;
		margin-bottom: 1em;
	}
	.social-links a,
	.license-info a {
		text-decoration: none;
		color: var(--font-color);
		font-weight: 400;
	}
	.social-links a:hover,
	.license-info a:hover {
		color: var(--accent-color);
		text-decoration: underline;
	}
	.license-info {
		font-size: 0.9em;
		line-height: 1.6;
	}
</style>
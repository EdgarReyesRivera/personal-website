---
import { SITE_NAME } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="site-name" href="/">{SITE_NAME}</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<!-- <HeaderLink href="/experiences">Experiences</HeaderLink> -->
			<!-- Hidden until experience write-ups are finished; see CLAUDE.md "Experiences section" -->

			<!-- <HeaderLink href="/blog">Blog</HeaderLink> -->
			<HeaderLink href="/skills">Skills</HeaderLink>
			<!-- <HeaderLink href="/coursework">Coursework</HeaderLink> -->
			<!-- Hidden until course write-ups are finished; see CLAUDE.md "Coursework section" -->

			<HeaderLink href="/resume">Resume</HeaderLink>
			<HeaderLink href="/about">About Me</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
	</nav>
</header>
<script>
	// On phones the nav links overflow into a scrollable row, and each page
	// load resets it to scrollLeft 0 — center the active link so it's visible
	// after navigating. Direct scrollLeft (not scrollIntoView) so the page
	// itself never scrolls. No-op on desktop where nothing overflows.
	function centerActiveNavLink() {
		const links = document.querySelector('.internal-links');
		const active = links?.querySelector('a.active');
		if (links instanceof HTMLElement && active instanceof HTMLElement && links.scrollWidth > links.clientWidth) {
			// offsetLeft is measured from the sticky header (nearest positioned
			// ancestor), so subtract the container's own offset to get the
			// link's position within the scrollable row.
			links.scrollLeft = (active.offsetLeft - links.offsetLeft) - (links.clientWidth - active.offsetWidth) / 2;
		}
	}
	centerActiveNavLink();
	// Re-center after every view-transition navigation (module scripts run once)
	document.addEventListener('astro:page-load', centerActiveNavLink);
</script>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		margin: 0;
		padding: 0 1em;
		background: rgba(var(--page-background-rgb), 0.85);
		-webkit-backdrop-filter: blur(10px);
		backdrop-filter: blur(10px);
		box-shadow: 0 2px 8px rgba(var(--shadow-color), 10%);
	}
	.site-name {
		font-size: 1.2em;
		font-weight: 700;
		white-space: nowrap;
		color: var(--font-color);
		text-decoration: none;
	}
	.site-name:hover {
		color: var(--accent-dark);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin: 0 auto;
	}
	nav .internal-links a {
		padding: 1em 0.5em;
		color: var(--font-color);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-weight: 700;
		transition: opacity 0.2s ease, color 0.2s ease;
	}
	nav .internal-links a:hover,
	nav .internal-links a:focus {
		opacity: 1;
		color: var(--accent-dark);
	}
	nav .internal-links a.active {
		text-decoration: none;
		border-bottom-color: var(--accent-color);
		color: var(--accent-dark);
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
	}
	@media (max-width: 720px) {
		header {
			padding: 0;
		}
		nav {
			flex-direction: column;
			align-items: stretch;
			padding-top: 0.6em;
		}
		.site-name {
			text-align: center;
			margin-bottom: 0.1em;
		}
		/* Single scrollable row instead of a wrapped blob of links */
		.internal-links {
			flex-wrap: nowrap;
			justify-content: flex-start;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			padding: 0 0.5em;
		}
		.internal-links::-webkit-scrollbar {
			display: none;
		}
		nav .internal-links a {
			padding: 0.5em 0.6em;
			font-size: 0.95em;
			white-space: nowrap;
			border-bottom-width: 3px;
		}
	}
</style>

---
// src/pages/skills.astro
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { COURSEWORK_ENABLED } from "../consts";

// `tags` are matched (case-insensitively) against project frontmatter tags to
// build the "where I've used this" panel for each skill. Skills without tags
// (or with no matching projects) render as plain, non-clickable chips.
type Skill = { name: string; level?: string; tags?: string[] };

const skillCategories: { title: string; skills: Skill[] }[] = [
  {
    title: "Languages",
    skills: [
      { name: "C++", level: "Proficient", tags: ["C++"] },
      { name: "C", level: "Proficient", tags: ["C"] },
      { name: "SystemVerilog", level: "Intermediate", tags: ["SystemVerilog"] },
      { name: "Verilog", level: "Intermediate", tags: ["Verilog"] },
      { name: "Python", level: "Intermediate", tags: ["Python"] },
      { name: "JavaScript", level: "Intermediate", tags: ["JavaScript", "TypeScript"] },
      { name: "Java", level: "Proficient", tags: ["Java"] },
      { name: "C#", level: "Intermediate", tags: ["C#"] },
      { name: "CUDA", level: "Learning", tags: ["CUDA"] },
      { name: "MIPS Assembly" },
      { name: "SQL", tags: ["SQL", "SQLite"] },
    ],
  },
  {
    title: "Hardware & Embedded Systems",
    skills: [
      { name: "FPGA Development (Vivado, Quartus)", tags: ["FPGA", "Vivado", "Quartus"] },
      { name: "RTL Design (SystemVerilog/Verilog)", tags: ["SystemVerilog", "Verilog", "RTL"] },
      { name: "RISC-V Architecture", tags: ["RISC-V"] },
      { name: "AXI4 Bus Protocols", tags: ["AXI4"] },
      { name: "Digital Circuit Design", tags: ["Digital Circuit Design"] },
      { name: "Hardware/Software Co-Design", tags: ["Hardware Accelerator", "Zynq"] },
      { name: "Serial Protocols (I2C, SPI, UART)", tags: ["I2C", "SPI", "UART"] },
    ],
  },
  {
    title: "Systems & Infrastructure",
    skills: [
      { name: "Linux Systems", tags: ["Linux", "Embedded Linux"] },
      { name: "Multi-threading", tags: ["Multi-threading", "SIMD"] },
      { name: "Virtualization (Proxmox)", tags: ["Proxmox", "Virtualization"] },
      { name: "Docker & Containerization", tags: ["Docker"] },
      { name: "Git & GitHub" },
    ],
  },
  {
    title: "Machine Learning & Data",
    skills: [
      { name: "Machine Learning", tags: ["Machine Learning", "Deep Learning"] },
      { name: "PyTorch", tags: ["PyTorch"] },
      { name: "scikit-learn", tags: ["scikit-learn"] },
      { name: "Computer Vision", tags: ["Computer Vision", "Image Processing"] },
      { name: "pandas", tags: ["pandas", "Data Pipelines"] },
      { name: "Statistical Analysis", tags: ["Statistics", "Quantitative Research"] },
    ],
  },
  {
    title: "Frameworks & Tools",
    skills: [
      { name: "React (Hooks, State Management)", tags: ["React"] },
      { name: "Firebase (Auth, Firestore)", tags: ["Firebase"] },
      { name: "Astro", tags: ["Astro"] },
      { name: "Tailwind CSS", tags: ["Tailwind CSS"] },
      { name: "Arduino", tags: ["Arduino"] },
      { name: "Matlab", tags: ["Matlab"] },
      { name: "Agile Methodologies" },
      { name: "JIRA / Bitbucket / Confluence" },
      { name: "Visual Studio / VSCode" },
    ],
  },
  {
    title: "Certifications",
    skills: [
      {
        name: "Ohio Southwest Alliance on Semiconductors and Integrated Scalable Manufacturing (O.A.S.I.S)",
      },
    ],
  },
];

// Match skills against project tags at build time.
// When the Experiences section is un-hidden, add getCollection('experiences')
// here — filtered to published entries, like courses below — and merge its
// matches (linking to /experiences/<id>/) the same way.
const projects = await getCollection("projects");
const courses = await getCollection("courses");

// Course links only render once the section is live AND the course is written;
// otherwise they'd point at pages that don't exist.
const linkableCourses = COURSEWORK_ENABLED
  ? courses.filter((c) => c.data.published)
  : [];

type Match = { title: string; url: string; status: string };
type CourseMatch = { title: string; url: string };

function matchesFor(skill: Skill): Match[] {
  if (!skill.tags) return [];
  const wanted = skill.tags.map((t) => t.toLowerCase());
  return projects
    .filter((p) =>
      (p.data.tags ?? []).some((tag) => wanted.includes(tag.toLowerCase())),
    )
    .map((p) => ({
      title: p.data.title,
      url: `/projects/${p.id}/`,
      status: p.data.status,
    }));
}

function courseMatchesFor(skill: Skill): CourseMatch[] {
  if (!skill.tags) return [];
  const wanted = skill.tags.map((t) => t.toLowerCase());
  return linkableCourses
    .filter((c) =>
      (c.data.tags ?? []).some((tag) => wanted.includes(tag.toLowerCase())),
    )
    .map((c) => ({
      title: c.data.title,
      url: `/coursework/${c.id}/`,
    }));
}

// Index-based ids: name-derived slugs collide (C, C++, C# all slug to "c")
const categories = skillCategories.map(({ title, skills }, catIndex) => ({
  title,
  skills: skills.map((skill, skillIndex) => ({
    ...skill,
    id: `${catIndex}-${skillIndex}`,
    matches: matchesFor(skill),
    courseMatches: courseMatchesFor(skill),
  })),
}));

// The "Relevant Coursework" list is driven by the courses collection; a name
// becomes a link only when the section is live and that course is published.
const departments = ["Computer Engineering", "Computer Science"] as const;
const courseworkByDepartment = departments.map((department) => ({
  department,
  courses: courses
    .filter((c) => c.data.department === department)
    .sort(
      (a, b) =>
        (a.data.order ?? Number.MAX_SAFE_INTEGER) -
          (b.data.order ?? Number.MAX_SAFE_INTEGER) ||
        a.data.title.localeCompare(b.data.title),
    ),
}));
---

<BaseLayout
  title="Skills & Expertise | Edgar Reyes-Rivera"
  description="A detailed look at my technical skills, hardware experience, and relevant coursework."
  width="wide"
>
  <div class="skills-wrapper">
    <header class="page-header">
      <h1>Skills & Expertise</h1>
      <p class="subtitle">
        A detailed breakdown of the languages, tools, and technologies I use to
        build hardware and software. Click a highlighted skill to see the
        projects where I've put it to work.
      </p>
    </header>

    <section>
      <h2 class="section-heading">Technical Skills</h2>
      {
        categories.map(({ title, skills }) => (
          <div class="skill-category">
            <h3>{title}</h3>
            <ul class="skill-list">
              {skills.map(({ name, level, id, matches, courseMatches }) => (
                <li>
                  {matches.length > 0 || courseMatches.length > 0 ? (
                    <button
                      class="chip chip-clickable"
                      aria-expanded="false"
                      aria-controls={`matches-${id}`}
                    >
                      {name}
                      {level && <span class="level">{level}</span>}
                      <span class="caret" aria-hidden="true">▾</span>
                    </button>
                  ) : (
                    <span class="chip">
                      {name}
                      {level && <span class="level">{level}</span>}
                    </span>
                  )}
                </li>
              ))}
              {/* Panels live in the same flex list as the chips; the script
                  moves the open one right after the clicked chip's row. */}
              {skills
                .filter(
                  ({ matches, courseMatches }) =>
                    matches.length > 0 || courseMatches.length > 0,
                )
                .map(({ name, id, matches, courseMatches }) => (
                  <li class="skill-matches" id={`matches-${id}`} hidden>
                    {matches.length > 0 && (
                      <>
                        <p class="matches-title">Where I've used {name}:</p>
                        <ul class="matches-list">
                          {matches.map(({ title: projectTitle, url, status }) => (
                            <li>
                              <a href={url}>{projectTitle}</a>
                              <span
                                class={`status-badge status-${status.toLowerCase()}`}
                              >
                                {status}
                              </span>
                            </li>
                          ))}
                        </ul>
                      </>
                    )}
                    {courseMatches.length > 0 && (
                      <div class="matches-courses">
                        <p class="matches-title">Related coursework:</p>
                        <div class="course-links">
                          {courseMatches.map(({ title: courseTitle, url }) => (
                            <a class="btn btn-sm" href={url}>
                              {courseTitle}
                            </a>
                          ))}
                        </div>
                      </div>
                    )}
                  </li>
                ))}
            </ul>
          </div>
        ))
      }
    </section>

    <section>
      <h2 class="section-heading">Relevant Coursework</h2>
      <p>
        Key courses from my dual-degree in Computer Engineering and Computer
        Science at Miami University.
      </p>
      <div class="course-grid">
        {
          courseworkByDepartment.map(({ department, courses }) => (
            <div class="course-category">
              <h3>{department}</h3>
              <ul>
                {courses.map((course) => (
                  <li>
                    {COURSEWORK_ENABLED && course.data.published ? (
                      <a href={`/coursework/${course.id}/`}>
                        {course.data.title}
                      </a>
                    ) : (
                      course.data.title
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .skills-wrapper {
    width: 100%;
    margin: auto;
  }
  section {
    margin-bottom: 3rem;
  }
  h3 {
    color: var(--accent-dark);
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }
  .skill-category {
    margin-bottom: 2rem;
  }
  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .chip .level {
    margin-left: 0.5em;
    padding-left: 0.6em;
    border-left: 1px solid var(--border-subtle);
    font-size: 0.8rem;
    color: var(--muted-color);
  }

  /* Chips backed by projects are interactive */
  button.chip-clickable {
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    border-color: var(--accent-color);
    transition: background-color 0.15s ease, transform 0.15s ease;
  }
  button.chip-clickable:hover {
    background-color: rgba(var(--tropical-indigo-rgb), 0.15);
    transform: translateY(-1px);
  }
  .chip .caret {
    display: inline-block;
    margin-left: 0.4em;
    font-size: 0.75em;
    color: var(--accent-dark);
    transition: transform 0.2s ease;
  }
  button.chip-clickable[aria-expanded="true"] {
    background-color: rgba(var(--tropical-indigo-rgb), 0.18);
  }
  button.chip-clickable[aria-expanded="true"] .caret {
    transform: rotate(180deg);
  }

  /* "Where I've used it" panel — a full-width flex row inside the chip
     list, so it always sits on its own line right under the clicked row */
  .skill-matches {
    flex-basis: 100%;
    margin: 0.25rem 0;
    padding: 1rem 1.25rem;
    background-color: var(--surface);
    border: 1px solid var(--border-subtle);
    border-left: 4px solid var(--accent-color);
    border-radius: var(--radius-md);
    animation: panel-in 0.18s ease-out;
  }
  @keyframes panel-in {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .matches-title {
    margin: 0 0 0.5rem;
    font-weight: 700;
    font-size: 0.95rem;
  }
  .matches-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .matches-list li {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-size: 1rem;
  }
  .matches-list a {
    font-weight: 700;
  }
  .matches-list + .matches-courses {
    margin-top: 0.85rem;
  }
  .course-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .course-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .course-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .course-category ul {
    list-style: none;
    padding-left: 0;
  }
  .course-category li {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.75rem;
    font-size: 1.05rem;
  }
  .course-category li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent-color);
    font-weight: bold;
  }
</style>

<script>
  // Toggle the "where I've used it" panel for a clicked skill chip.
  // Only one panel is open per category at a time.

  // Move the panel <li> right after the last chip in the clicked chip's
  // visual row (same offsetTop), so it opens directly under that row
  // instead of at the bottom of the category.
  function positionPanel(panel: HTMLElement, chipItem: HTMLElement) {
    const list = chipItem.parentElement;
    if (!list) return;
    const wasHidden = panel.hidden;
    panel.hidden = true; // don't let the panel itself shift rows while measuring
    const rowTop = chipItem.offsetTop;
    let rowEnd = chipItem;
    list
      .querySelectorAll<HTMLElement>("li:not(.skill-matches)")
      .forEach((item) => {
        if (Math.abs(item.offsetTop - rowTop) < 4) rowEnd = item;
      });
    rowEnd.after(panel);
    panel.hidden = wasHidden;
  }

  // Bound per navigation: view transitions replace the DOM without re-running
  // this module script, so re-bind on astro:page-load (the data-bound guard
  // prevents double-binding on the initial load, where both paths run).
  function initSkillPanels() {
  document
    .querySelectorAll<HTMLButtonElement>(".chip-clickable")
    .forEach((button) => {
      if (button.dataset.bound) return;
      button.dataset.bound = "true";
      button.addEventListener("click", () => {
        const panelId = button.getAttribute("aria-controls");
        const panel = panelId ? document.getElementById(panelId) : null;
        const chipItem = button.closest("li");
        const category = button.closest(".skill-category");
        if (!panel || !chipItem || !category) return;

        const wasOpen = !panel.hidden;
        category
          .querySelectorAll<HTMLElement>(".skill-matches")
          .forEach((p) => (p.hidden = true));
        category
          .querySelectorAll(".chip-clickable")
          .forEach((b) => b.setAttribute("aria-expanded", "false"));

        if (!wasOpen) {
          positionPanel(panel, chipItem);
          panel.hidden = false;
          button.setAttribute("aria-expanded", "true");
        }
      });
    });
  }
  initSkillPanels();
  document.addEventListener("astro:page-load", initSkillPanels);

  // Rows re-wrap when the viewport changes (e.g. phone rotation); keep any
  // open panel under its chip's row.
  let resizeTimer: ReturnType<typeof setTimeout> | undefined;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      document
        .querySelectorAll<HTMLElement>(".skill-matches:not([hidden])")
        .forEach((panel) => {
          const button = document.querySelector(
            `[aria-controls="${panel.id}"]`,
          );
          const chipItem = button?.closest("li");
          if (chipItem) positionPanel(panel, chipItem);
        });
    }, 100);
  });
</script>

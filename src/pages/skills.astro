---
// src/pages/skills.astro
import BaseLayout from "../layouts/BaseLayout.astro";

type Skill = { name: string; level?: string };

const skillCategories: { title: string; skills: Skill[] }[] = [
  {
    title: "Languages",
    skills: [
      { name: "C++", level: "Proficient" },
      { name: "C", level: "Proficient" },
      { name: "SystemVerilog", level: "Intermediate" },
      { name: "Verilog", level: "Intermediate" },
      { name: "Python", level: "Intermediate" },
      { name: "JavaScript", level: "Intermediate" },
      { name: "Java", level: "Proficient" },
      { name: "C#", level: "Intermediate" },
      { name: "CUDA", level: "Learning" },
      { name: "MIPS Assembly" },
      { name: "SQL" },
    ],
  },
  {
    title: "Hardware & Embedded Systems",
    skills: [
      { name: "FPGA Development (Vivado, Quartus)" },
      { name: "RTL Design (SystemVerilog/Verilog)" },
      { name: "RISC-V Architecture" },
      { name: "AXI4 Bus Protocols" },
      { name: "Digital Circuit Design" },
      { name: "Hardware/Software Co-Design" },
      { name: "Serial Protocols (I2C, SPI, UART)" },
    ],
  },
  {
    title: "Systems & Infrastructure",
    skills: [
      { name: "Linux Systems" },
      { name: "Multi-threading" },
      { name: "Virtualization (Proxmox)" },
      { name: "Docker & Containerization" },
      { name: "Git & GitHub" },
    ],
  },
  {
    title: "Frameworks & Tools",
    skills: [
      { name: "React (Hooks, State Management)" },
      { name: "Firebase (Auth, Firestore)" },
      { name: "Arduino" },
      { name: "Matlab" },
      { name: "Agile Methodologies" },
      { name: "JIRA / Bitbucket / Confluence" },
      { name: "Visual Studio / VSCode" },
    ],
  },
  {
    title: "Certifications",
    skills: [
      {
        name: "Ohio Southwest Alliance on Semiconductors and Integrated Scalable Manufacturing (O.A.S.I.S)",
      },
    ],
  },
];
---

<BaseLayout
  title="Skills & Expertise | Edgar Reyes-Rivera"
  description="A detailed look at my technical skills, hardware experience, and relevant coursework."
  width="wide"
>
  <div class="skills-wrapper">
    <header class="page-header">
      <h1>Skills & Expertise</h1>
      <p class="subtitle">
        A detailed breakdown of the languages, tools, and technologies I use to
        build hardware and software.
      </p>
    </header>

    <section>
      <h2 class="section-heading">Technical Skills</h2>
      {
        skillCategories.map(({ title, skills }) => (
          <div class="skill-category">
            <h3>{title}</h3>
            <ul class="skill-list">
              {skills.map(({ name, level }) => (
                <li class="chip">
                  {name}
                  {level && <span class="level">{level}</span>}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </section>

    <section>
      <h2 class="section-heading">Relevant Coursework</h2>
      <p>
        Key courses from my dual-degree in Computer Engineering and Computer
        Science at Miami University.
      </p>
      <div class="course-grid">
        <div class="course-category">
          <h3>Computer Engineering</h3>
          <ul>
            <li>Digital Systems Design</li>
            <li>Computer Organization</li>
            <li>Embedded Systems Design</li>
            <li>Electric Circuit Analysis I</li>
            <li>Elements of Robotics</li>
            <li>Signals and Systems</li>
            <li>Network Performance Analysis</li>
          </ul>
        </div>
        <div class="course-category">
          <h3>Computer Science</h3>
          <ul>
            <li>Data Abstractions & Structures</li>
            <li>Algorithms I</li>
            <li>Object-Oriented Programming</li>
            <li>Systems I & II</li>
            <li>Database Systems</li>
            <li>Comparative Programming Languages</li>
            <li>Deep Learning</li>
            <li>Image Processing</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .skills-wrapper {
    width: 100%;
    margin: auto;
  }
  section {
    margin-bottom: 3rem;
  }
  h3 {
    color: var(--accent-dark);
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }
  .skill-category {
    margin-bottom: 2rem;
  }
  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .chip .level {
    margin-left: 0.5em;
    padding-left: 0.6em;
    border-left: 1px solid var(--border-subtle);
    font-size: 0.8rem;
    color: var(--muted-color);
  }

  .course-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .course-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .course-category ul {
    list-style: none;
    padding-left: 0;
  }
  .course-category li {
    position: relative;
    padding-left: 1.75rem;
    margin-bottom: 0.75rem;
    font-size: 1.05rem;
  }
  .course-category li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent-color);
    font-weight: bold;
  }
</style>

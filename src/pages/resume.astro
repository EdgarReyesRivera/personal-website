---
// src/pages/resume.astro
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';
import BaseLayout from '../layouts/BaseLayout.astro';
import { RESUME_UPDATED } from '../consts';

// Build-time content hash of the PDF: replacing resume.pdf automatically busts
// browser/CDN caches, no manual ?v= bump needed. Runs only at build (static site).
const pdfHash = createHash('sha256')
	.update(readFileSync(new URL('../../public/resume.pdf', import.meta.url)))
	.digest('hex')
	.slice(0, 8);
const resumeHref = `/resume.pdf?v=${pdfHash}`;
---

<BaseLayout
	title="Resume | Edgar Reyes-Rivera"
	description="View and download the resume for Edgar Reyes-Rivera."
>
	<div class="resume-wrapper">
		<header class="page-header">
			<h1>My Resume</h1>
			<p class="subtitle">
				View my most recent resume below, or grab a copy to take with you.
			</p>
			<p class="last-updated">Last updated: {RESUME_UPDATED}</p>
		</header>

		<div class="resume-actions">
			<a href={resumeHref} target="_blank" rel="noopener" class="btn open-button">
				Open Resume (PDF)
			</a>
			<a
				href={resumeHref}
				download="EdgarReyesRivera_Resume.pdf"
				class="btn"
			>
				Download a Copy
			</a>
		</div>

		<!-- Inline preview for larger screens; phones get the buttons above,
		     since mobile browsers render PDF iframes as a blank box. -->
		<div class="pdf-embed">
			<iframe
                src={resumeHref}
                title="Edgar Reyes-Rivera's Resume"
                width="100%"
                height="800px"
            >
            </iframe>
		</div>

		<aside class="explore-strip">
			<p>Want the full story behind the bullet points?</p>
			<nav class="explore-links">
				<a href="/projects" class="btn btn-sm">Explore My Projects</a>
				<a href="/contact" class="btn btn-sm">Get in Touch</a>
			</nav>
		</aside>
	</div>
</BaseLayout>

<style>
	.resume-wrapper {
		text-align: center;
	}
	.last-updated {
		margin: 0.75rem 0 0;
		font-size: 0.95rem;
		color: var(--muted-color);
	}
	.resume-actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.pdf-embed {
		width: 100%;
		margin: auto;
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-md);
		overflow: hidden; /* To apply border-radius to iframe */
	}
	.pdf-embed iframe {
		border: none;
		display: block;
	}

	.explore-strip {
		margin-top: 3rem;
		padding: 1.5rem;
		background-color: var(--surface);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-lg);
	}
	.explore-strip p {
		margin: 0 0 1rem;
		font-size: 1.05rem;
		color: var(--muted-color);
	}
	.explore-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
	}

	@media (max-width: 767px) {
		/* Mobile browsers can't render the PDF inline — hide the dead iframe
		   and let the buttons open it in the native full-screen viewer. */
		.pdf-embed {
			display: none;
		}
		.resume-actions {
			flex-direction: column;
			align-items: stretch;
			max-width: 380px;
			margin: 0 auto 1rem;
		}
		.explore-strip {
			margin-top: 2rem;
		}
	}
</style>

---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';

// Get featured projects
const allProjects = await getCollection('projects');
const featuredProjects = allProjects
    .filter(project => project.data.featured)
    .sort((a, b) => {
	const aDate = a.data.pubDate;
	const bDate = b.data.pubDate;

	if (aDate && bDate) {
		// Both projects have a date, sort newest first
		return bDate.valueOf() - aDate.valueOf();
	} else if (aDate && !bDate) {
		// 'a' has a date, 'b' does not. 'a' comes first.
		return -1;
	} else if (!aDate && bDate) {
		// 'b' has a date, 'a' does not. 'b' comes first.
		return 1;
	} else {
		// Neither project has a date, keep their original order.
		return 0;
	}
});

// Set `href` on a highlight to make its card a link. Industry Experience and
// Leadership will point at the Synchrony/SHPE experience pages once the
// Experiences section is un-hidden (see CLAUDE.md), e.g. href: '/experiences/<slug>'.
type Highlight = { label: string; detail: string; href?: string };
const highlights: Highlight[] = [
    { label: 'Dual Major', detail: 'Computer Engineering & Computer Science, Miami University' },
    { label: 'Industry Experience', detail: 'Software Engineer Intern @ Synchrony' },
    { label: 'Leadership', detail: 'President, SHPE Miami University Chapter' },
    { label: 'Class of 2027', detail: 'Graduating May 2027 · Seeking full-time roles' },
];
---

<BaseLayout title="Edgar Reyes-Rivera | Computer Engineering & Computer Science" description={SITE_DESCRIPTION} width="wide">
    <div class="hero">
        <div class="intro-text">
            <h1 class="gradient-text">Edgar Reyes-Rivera</h1>
            <p class="tagline">
                Dual Major Computer Engineering & Computer Science Student
            </p>
            <p class="availability">
                Graduating May 2027 · Seeking full-time opportunities
            </p>
            <p class="bio">
                I'm passionate about building robust, high-performance systems from the
                ground up. I thrive on the challenges found at the intersection of
                hardware and software.
            </p>
        </div>

        <nav class="cta-nav">
            <a href="/projects" class="btn">
                View My Work
            </a>
            <a href="/resume" class="btn">
                My Resume
            </a>
            <a href="/contact" class="btn">
                Get in Touch
            </a>
        </nav>
    </div>

    <ul class="highlights">
        {
            highlights.map(({ label, detail, href }) => (
                <li>
                    {href ? (
                        <a class="highlight-card is-link" href={href}>
                            <span class="highlight-label">{label} <span class="arrow">→</span></span>
                            <span class="highlight-detail">{detail}</span>
                        </a>
                    ) : (
                        <div class="highlight-card">
                            <span class="highlight-label">{label}</span>
                            <span class="highlight-detail">{detail}</span>
                        </div>
                    )}
                </li>
            ))
        }
    </ul>

    <section class="featured-work">
        <h2>Featured Work</h2>
        <p>A selection of my recent projects. See all projects <a href="/projects">here</a>.</p>
        <ul class="project-grid">
            {
                featuredProjects.map((project) => (
                    <ProjectCard project={project} />
                ))
            }
        </ul>
    </section>
</BaseLayout>

<style>
    .hero {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 3rem 0 3.5rem;
    }

    .intro-text h1 {
        font-size: clamp(2.4rem, 6vw, 3.5rem);
        margin: 0;
        line-height: 1.15;
    }

    .tagline {
        font-size: clamp(1.1rem, 3vw, 1.4rem);
        font-weight: 700;
        color: var(--accent-dark);
        margin: 0.75rem 0 0;
    }

    .availability {
        font-size: 1rem;
        font-weight: 500;
        color: var(--muted-color);
        margin: 0.5rem 0 1.5rem;
    }

    .bio {
        font-size: 1.15rem;
        max-width: 600px;
        margin: 0 auto 2.5rem;
        opacity: 0.9;
    }

    .cta-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
    }

    /* Highlights strip: quick credibility markers */
    .highlights {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        list-style: none;
        margin: 0 auto 4rem;
        padding: 0;
        max-width: 1000px;
    }
    @media (min-width: 1024px) {
        .highlights {
            grid-template-columns: repeat(4, 1fr);
            max-width: none;
        }
    }
    .highlight-card {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        height: 100%;
        box-sizing: border-box;
        background-color: var(--surface);
        border: 1px solid var(--border-subtle);
        border-left: 4px solid var(--accent-color);
        border-radius: var(--radius-md);
        padding: 0.9rem 1.1rem;
    }
    /* Linked cards (future experience pages) get hover affordance */
    a.highlight-card {
        text-decoration: none;
        color: var(--font-color);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    a.highlight-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }
    a.highlight-card .arrow {
        transition: transform 0.2s ease;
        display: inline-block;
    }
    a.highlight-card:hover .arrow {
        transform: translateX(3px);
    }
    .highlight-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--accent-dark);
    }
    .highlight-detail {
        font-size: 0.98rem;
        line-height: 1.45;
    }

    .featured-work h2 {
        margin-top: 0.5em;
        text-align: center;
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        margin-bottom: 0.5rem;
    }
    .featured-work h2::after {
        content: '';
        display: block;
        width: 64px;
        height: 4px;
        border-radius: 2px;
        background: var(--accent-gradient);
        margin: 0.85rem auto 0;
    }
    .featured-work p {
        text-align: center;
        font-size: 1.15rem;
        max-width: 600px;
        margin: 1rem auto 2.5rem;
        color: var(--muted-color);
    }

    .project-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
    }
    @media (min-width: 768px) {
        .project-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1024px) {
        .project-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @media (max-width: 720px) {
        .hero {
            padding: 2rem 0 2.5rem;
        }
        .cta-nav {
            flex-direction: column;
            align-items: stretch;
            width: 100%;
            max-width: 380px;
        }
        .highlights {
            grid-template-columns: 1fr;
            gap: 0.75rem;
            margin-bottom: 3rem;
        }
    }
</style>

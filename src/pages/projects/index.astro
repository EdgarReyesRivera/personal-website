---
// src/pages/projects/index.astro
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { sortProjectsByDate } from '../../utils/projects';

// Get the 'status' from the URL query.
// This is still useful for filtering the *list* of projects.
const statusFilter = Astro.url.searchParams.get('status');

const allProjects = sortProjectsByDate(await getCollection('projects'));

// We no longer filter here on the server.
// Let the client-side script handle showing/hiding.
const filteredProjects = allProjects;

const allStatuses = ['Completed', 'In-Progress', 'Future'];
---

<BaseLayout
    title="Projects | Edgar Reyes-Rivera"
    description="A showcase of technical projects by Edgar Reyes-Rivera."
    width="wide"
>
    <section>
        <header class="page-header">
            <h1>My Projects</h1>
            <p class="subtitle">
                A collection of my technical projects, from hardware design to
                full-stack software.
            </p>
        </header>

        <nav class="filter-nav">
            <a href="/projects" class="btn btn-sm filter-button">
                All
            </a>
            {
                allStatuses.map((status) => (
                    <a
                        href={`/projects?status=${status}`}
                        class="btn btn-sm filter-button"
                    >
                        {status}
                    </a>
                ))
            }
        </nav>
        <ul class="project-grid">
            {
                filteredProjects.map((project) => (
                    <ProjectCard project={project} /> ))
            }
        </ul>
    </section>
</BaseLayout>

<style>
    .filter-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
        margin-bottom: 2.5rem;
    }

    /* Filled state for the active filter (hover comes from .btn) */
    .filter-button.active {
        background-color: var(--accent-color);
        color: var(--page-background);
    }

    .project-grid {
        display: grid;
        grid-template-columns: 1fr; /* 1 column on mobile */
        gap: 2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
    }

    @media (min-width: 768px) {
        .project-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1024px) {
        .project-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>

<script>
    // Runs once per hard load, then again after every view-transition
    // navigation (the DOM — and possibly the ?status filter — is new each time).
    function markActiveFilter() {
    // Get the search parameters from the browser's current URL
    const urlParams = new URLSearchParams(window.location.search);
    const statusFilter = urlParams.get('status');

    // --- Filter the cards ---
    // The style injected by BaseHead only covers the initial hard load (it
    // doesn't survive the view-transition head swap), so the runtime filter
    // lives here: retire the injected style and set each card directly.
    document.getElementById('project-status-filter')?.remove();
    document.querySelectorAll<HTMLElement>('.project-card').forEach((card) => {
        card.style.display =
            !statusFilter || card.dataset.status === statusFilter ? '' : 'none';
    });

    // Find all buttons
    const filterButtons = document.querySelectorAll<HTMLAnchorElement>('.filter-button');

    // --- Set the active button state ---
    filterButtons.forEach(button => {
        // Get the 'href' attribute from the button
        const href = button.getAttribute('href');
        
        if (href) {
            // 1. Check the "All" button
            if (href === '/projects') {
                if (!statusFilter) {
                    // If there's no status in the URL, "All" is active
                    button.classList.add('active');
                }
            } 
            
            // 2. Check the other status buttons
            else {
                try {
                    // This line is now safe from the TypeScript error
                    const buttonStatus = new URL(href, window.location.origin).searchParams.get('status');

                    // If the button's status matches the URL's status, it's active
                    if (buttonStatus === statusFilter) {
                        button.classList.add('active');
            
                    }
                } catch (e) {
                    console.error("Could not parse button URL:", e);
                }
            }
        }
    });
    }
    markActiveFilter();
    document.addEventListener('astro:page-load', markActiveFilter);
</script>
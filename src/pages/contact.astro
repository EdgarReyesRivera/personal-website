---
// src/pages/contact.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact Me | Edgar Reyes-Rivera"
  description="Get in touch with Edgar Reyes-Rivera via email, LinkedIn, or GitHub."
>
  <div class="contact-wrapper">
    <h1>Contact Me</h1>
    <p>
      I'm always open to discussing new projects, creative ideas, or
      opportunities to be part of your vision.
    </p>

    <div class="contact-links">
      <a href="mailto:edgar@reyesrivera.dev" class="contact-button email">
        Email
      </a>
      <a
        href="https://www.linkedin.com/in/edgar-reyes-rivera/"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-button linkedin"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com/EdgarReyesRivera"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-button github"
      >
        <span class="icon">GitHub</span>
      </a>
    </div>

    <div class="calendar-container">
      <h2>Schedule a Meeting</h2>
      <div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline">
      </div>
      <script type="text/javascript">
        (function (C, A, L) {
          let p = function (a, ar) {
            a.q.push(ar);
          };
          let d = C.document;
          C.Cal =
            C.Cal ||
            function () {
              let cal = C.Cal;
              let ar = arguments;
              if (!cal.loaded) {
                cal.ns = {};
                cal.q = cal.q || [];
                d.head.appendChild(d.createElement("script")).src = A;
                cal.loaded = true;
              }
              if (ar[0] === L) {
                const api = function () {
                  p(api, arguments);
                };
                const namespace = ar[1];
                api.q = api.q || [];
                typeof namespace === "string"
                  ? (cal.ns[namespace] = api) && p(api, arguments)
                  : p(cal, arguments);
                return api;
              }
              p(cal, arguments);
            };
        })(window, "https://app.cal.com/embed/embed.js", "init");
        Cal("init", "30min", { origin: "https://cal.com" });

        Cal("inline", {
          elementOrSelector: "#my-cal-inline",
          calLink: "edgar-reyes-rivera",
          layout: "month_view",
        });

        Cal("ui", {
          styles: { branding: { brandColor: "#8d86c9" } },
          hideEventTypeDetails: false,
          layout: "month_view",
        });
      </script>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-wrapper {
    max-width: 800px; /* Increased width to fit calendar comfortably */
    margin: auto;
    text-align: center;
  }
  h1 {
    margin-bottom: 1rem;
  }
  p {
    font-size: 1.15rem;
    margin-bottom: 2rem;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  .contact-button {
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    font-size: 1rem;
    box-shadow: 0 2px 4px rgba(var(--shadow-color), 0.1);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .contact-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 5px 15px rgba(var(--shadow-color), 0.25);
  }
  .contact-button.email {
    background-color: var(--accent-color);
    color: var(--ghost-white);
  }
  .contact-button.github {
    background-color: #333;
    color: white;
  }
  .contact-button.linkedin {
    background-color: #0077b5;
    color: white;
  }

  .calendar-container {
    margin-top: 2rem;
    /*height: 600px; /* Force height for the calendar */
    border: 1px solid rgba(var(--raisin-black-rgb), 0.1);
    border-radius: 12px;
    overflow: hidden;
  }
  .calendar-container h2 {
    margin-top: 1rem;
    font-size: 1.5rem;
  }
</style>

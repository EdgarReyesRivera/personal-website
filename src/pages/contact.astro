---
// src/pages/contact.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact Me | Edgar Reyes-Rivera"
  description="Get in touch with Edgar Reyes-Rivera via email, LinkedIn, or GitHub."
  width="wide"
>
  <div class="contact-wrapper">
    <header class="page-header">
      <h1>Contact Me</h1>
      <p class="subtitle">
        I'm always open to discussing new projects, creative ideas, or
        opportunities to be part of your vision.
      </p>
    </header>

    <div class="contact-links">
      <!-- email_off/email_off comments tell Cloudflare's Email Address Obfuscation
           to leave these alone — its decode script doesn't re-run after
           view-transition navigations, leaving "[email protected]" and a dead
           /cdn-cgi/ link. Wrap any future email occurrences the same way. -->
      <!--email_off-->
      <a href="mailto:edgar@reyesrivera.dev" class="btn contact-button email">
        Email
      </a>
      <!--/email_off-->
      <a
        href="https://www.linkedin.com/in/edgar-reyes-rivera/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn contact-button linkedin"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com/EdgarReyesRivera"
        target="_blank"
        rel="noopener noreferrer"
        class="btn contact-button github"
      >
        GitHub
      </a>
    </div>

    <!-- The Email button above opens a mail app; this row is for everyone
         else — copy the address, or save a vCard straight to your phone. -->
    <div class="direct-row">
      <!--email_off-->
      <span class="email-text">edgar@reyesrivera.dev</span>
      <button type="button" class="btn btn-sm copy-email" data-email="edgar@reyesrivera.dev">
        Copy
      </button>
      <!--/email_off-->
      <a href="/edgar-reyes-rivera.vcf" download="EdgarReyesRivera.vcf" class="btn btn-sm">
        Save my contact
      </a>
    </div>

    <div class="calendar-container">
      <h2>Schedule a Meeting</h2>
      <div id="my-cal-inline"></div>
      <!-- data-astro-rerun: view transitions give this page a fresh (empty)
           embed div without re-running inline scripts by default; re-running
           re-mounts the calendar (the loader itself only ever loads once). -->
      <script type="text/javascript" data-astro-rerun>
        (function (C, A, L) {
          let p = function (a, ar) {
            a.q.push(ar);
          };
          let d = C.document;
          C.Cal =
            C.Cal ||
            function () {
              let cal = C.Cal;
              let ar = arguments;
              if (!cal.loaded) {
                cal.ns = {};
                cal.q = cal.q || [];
                d.head.appendChild(d.createElement("script")).src = A;
                cal.loaded = true;
              }
              if (ar[0] === L) {
                const api = function () {
                  p(api, arguments);
                };
                const namespace = ar[1];
                api.q = api.q || [];
                typeof namespace === "string"
                  ? (cal.ns[namespace] = api) && p(api, arguments)
                  : p(cal, arguments);
                return api;
              }
              p(cal, arguments);
            };
        })(window, "https://app.cal.com/embed/embed.js", "init");
        Cal("init", "30min", { origin: "https://cal.com" });

        Cal("inline", {
          elementOrSelector: "#my-cal-inline",
          calLink: "edgar-reyes-rivera",
          layout: "month_view",
        });

        Cal("ui", {
          styles: { branding: { brandColor: "#8d86c9" } },
          hideEventTypeDetails: false,
          layout: "month_view",
        });
      </script>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-wrapper {
    max-width: 900px; /* Wide enough for the calendar to breathe on desktop */
    margin: auto;
    text-align: center;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  /* Small brand-color cue on the outline buttons, without leaving the palette */
  .contact-button::before {
    content: '';
    width: 0.6em;
    height: 0.6em;
    border-radius: 50%;
  }
  .contact-button.email::before {
    background-color: var(--accent-color);
  }
  .contact-button.linkedin::before {
    background-color: #0077b5;
  }
  .contact-button.github::before {
    background-color: #333;
  }
  @media (prefers-color-scheme: dark) {
    .contact-button.github::before {
      background-color: #f5f2f8;
    }
  }

  .direct-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }
  .email-text {
    font-size: 1.05rem;
    color: var(--muted-color);
  }
  /* Reserve width so the label swap to "Copied!" doesn't shift the row */
  .copy-email {
    min-width: 6.5rem;
  }

  .calendar-container {
    margin-top: 2rem;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding-bottom: 1rem;
    overflow: hidden;
  }
  .calendar-container h2 {
    margin-top: 1rem;
    font-size: 1.5rem;
  }
  #my-cal-inline {
    width: 100%;
    min-height: 500px;
  }

  @media (max-width: 720px) {
    .contact-links {
      flex-direction: column;
      align-items: stretch;
      max-width: 380px;
      margin: 0 auto 1.5rem;
    }
  }
</style>

<script>
  // Copy-email button. Bound idempotently (data-bound guard) and re-run on
  // astro:page-load so it keeps working if/when view transitions are enabled.
  function initCopyEmail() {
    document.querySelectorAll<HTMLButtonElement>('.copy-email').forEach((button) => {
      if (button.dataset.bound) return;
      button.dataset.bound = 'true';

      const originalLabel = button.textContent;
      button.addEventListener('click', async () => {
        const email = button.dataset.email ?? '';
        try {
          await navigator.clipboard.writeText(email);
          button.textContent = 'Copied!';
        } catch {
          // Clipboard API unavailable (old browser / insecure context)
          button.textContent = 'Copy failed';
        }
        setTimeout(() => {
          button.textContent = originalLabel;
        }, 1800);
      });
    });
  }
  initCopyEmail();
  document.addEventListener('astro:page-load', initCopyEmail);
</script>

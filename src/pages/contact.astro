---
// src/pages/contact.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact Me | Edgar Reyes-Rivera"
  description="Get in touch with Edgar Reyes-Rivera via email, LinkedIn, or GitHub."
  width="wide"
>
  <div class="contact-wrapper">
    <header class="page-header">
      <h1>Contact Me</h1>
      <p class="subtitle">
        I'm always open to discussing new projects, creative ideas, or
        opportunities to be part of your vision.
      </p>
    </header>

    <div class="contact-links">
      <a href="mailto:edgar@reyesrivera.dev" class="btn contact-button email">
        Email
      </a>
      <a
        href="https://www.linkedin.com/in/edgar-reyes-rivera/"
        target="_blank"
        rel="noopener noreferrer"
        class="btn contact-button linkedin"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com/EdgarReyesRivera"
        target="_blank"
        rel="noopener noreferrer"
        class="btn contact-button github"
      >
        GitHub
      </a>
    </div>

    <p class="email-plain">
      Or reach me directly at
      <a href="mailto:edgar@reyesrivera.dev">edgar@reyesrivera.dev</a>
    </p>

    <div class="calendar-container">
      <h2>Schedule a Meeting</h2>
      <div id="my-cal-inline"></div>
      <script type="text/javascript">
        (function (C, A, L) {
          let p = function (a, ar) {
            a.q.push(ar);
          };
          let d = C.document;
          C.Cal =
            C.Cal ||
            function () {
              let cal = C.Cal;
              let ar = arguments;
              if (!cal.loaded) {
                cal.ns = {};
                cal.q = cal.q || [];
                d.head.appendChild(d.createElement("script")).src = A;
                cal.loaded = true;
              }
              if (ar[0] === L) {
                const api = function () {
                  p(api, arguments);
                };
                const namespace = ar[1];
                api.q = api.q || [];
                typeof namespace === "string"
                  ? (cal.ns[namespace] = api) && p(api, arguments)
                  : p(cal, arguments);
                return api;
              }
              p(cal, arguments);
            };
        })(window, "https://app.cal.com/embed/embed.js", "init");
        Cal("init", "30min", { origin: "https://cal.com" });

        Cal("inline", {
          elementOrSelector: "#my-cal-inline",
          calLink: "edgar-reyes-rivera",
          layout: "month_view",
        });

        Cal("ui", {
          styles: { branding: { brandColor: "#8d86c9" } },
          hideEventTypeDetails: false,
          layout: "month_view",
        });
      </script>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-wrapper {
    max-width: 900px; /* Wide enough for the calendar to breathe on desktop */
    margin: auto;
    text-align: center;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  /* Small brand-color cue on the outline buttons, without leaving the palette */
  .contact-button::before {
    content: '';
    width: 0.6em;
    height: 0.6em;
    border-radius: 50%;
  }
  .contact-button.email::before {
    background-color: var(--accent-color);
  }
  .contact-button.linkedin::before {
    background-color: #0077b5;
  }
  .contact-button.github::before {
    background-color: #333;
  }
  @media (prefers-color-scheme: dark) {
    .contact-button.github::before {
      background-color: #f5f2f8;
    }
  }

  .email-plain {
    font-size: 1.05rem;
    color: var(--muted-color);
    margin-bottom: 3rem;
  }

  .calendar-container {
    margin-top: 2rem;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding-bottom: 1rem;
    overflow: hidden;
  }
  .calendar-container h2 {
    margin-top: 1rem;
    font-size: 1.5rem;
  }
  #my-cal-inline {
    width: 100%;
    min-height: 500px;
  }

  @media (max-width: 720px) {
    .contact-links {
      flex-direction: column;
      align-items: stretch;
      max-width: 380px;
      margin: 0 auto 1.5rem;
    }
  }
</style>

---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ExperienceLayout from '../../layouts/ExperienceLayout.astro';

export async function getStaticPaths() {
	// Unpublished scaffolds never get routes (same safety layer as courses).
	const experiences = await getCollection('experiences', ({ data }) => data.published);
	return experiences.map((experience) => ({
		params: { slug: experience.id },
		props: experience,
	}));
}
type Props = CollectionEntry<'experiences'>;

const experience = Astro.props;
const { Content } = await render(experience);
---

<ExperienceLayout {...experience.data}>
	<Content />
</ExperienceLayout>

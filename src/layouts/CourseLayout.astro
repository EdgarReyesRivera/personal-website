---
// src/layouts/CourseLayout.astro
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

type Props = CollectionEntry<'courses'>['data'];

const { title, description, courseCode, department, term, tags, projects: projectIds } = Astro.props;

// Resolve the explicit `projects` frontmatter ids against the projects
// collection; fail the build on a typo rather than silently dropping a link.
const allProjects = await getCollection('projects');
const courseProjects = (projectIds ?? []).map((id) => {
	const project = allProjects.find((p) => p.id === id);
	if (!project) {
		throw new Error(`Course "${title}" references unknown project id "${id}"`);
	}
	return project;
});
---

<BaseLayout title={`${title} | Edgar Reyes-Rivera`} description={description}>
	<article>
		<div class="prose">
			<div class="title">
				<h1>{title}</h1>
				<div class="meta">
					<p>
						{[courseCode, department, term].filter(Boolean).join(' · ')}
					</p>
				</div>
				{
					tags && tags.length > 0 && (
						<ul class="tag-list">
							{tags.map((tag) => (
								<li class="chip">{tag}</li>
							))}
						</ul>
					)
				}
				<hr />
			</div>
			<slot />
			{
				courseProjects.length > 0 && (
					<section class="course-projects">
						<h2>Projects from this course</h2>
						<ul>
							{courseProjects.map((project) => (
								<li>
									<a href={`/projects/${project.id}/`}>{project.data.title}</a>
									<span class={`status-badge status-${project.data.status.toLowerCase()}`}>
										{project.data.status}
									</span>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</div>
	</article>
</BaseLayout>

<style>
	.prose {
		width: 100%;
		margin: auto;
	}
	.title {
		margin-bottom: 1em;
		padding: 1em 0;
		text-align: center;
		line-height: 1;
	}
	.title h1 {
		margin: 0 0 0.5em 0;
	}
	.meta {
		margin-bottom: 0.5em;
		color: var(--muted-color);
	}
	.meta p {
		margin: 0 0 0.5em 0;
	}
	.tag-list {
		list-style: none;
		margin: 0 0 1em 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5rem;
		line-height: 1.5;
	}
	.course-projects {
		margin-top: 3rem;
	}
	.course-projects ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.course-projects li {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.course-projects a {
		font-weight: 700;
	}
</style>

---
// src/layouts/BaseLayout.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface Props {
	title?: string;
	description?: string;
	image?: ImageMetadata;
	/** 'default' = 720px reading width, 'wide' = 1100px for image/grid-heavy pages */
	width?: 'default' | 'wide';
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION, image, width = 'default' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class:list={[{ wide: width === 'wide' }]}>
			<slot /> </main>
		<Footer />
	</body>
</html>